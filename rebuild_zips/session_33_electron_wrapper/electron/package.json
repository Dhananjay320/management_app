{
  "name": "avadeti-team-desktop",
  "version": "1.0.0",
  "description": "Avadeti Team — desktop app wrapper",
  "main": "main.js",
  "author": "Avadeti",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "//  DEVELOPMENT  ": "--",
    "start": "electron .",
    "dev": "concurrently -k -n client,server,electron \"cd ../client && npm start\" \"cd ../server && npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
    "//  BUILD  ": "--",
    "prebuild": "cd ../client && CI=true DISABLE_ESLINT_PLUGIN=true npm run build",
    "build": "electron-builder --publish never",
    "build:win": "electron-builder --win --publish never",
    "build:mac": "electron-builder --mac --publish never",
    "build:linux": "electron-builder --linux --publish never",
    "//  RELEASE (Session 34)  ": "--",
    "release": "electron-builder --publish always"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "concurrently": "^8.2.2",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.avadeti.team",
    "productName": "Avadeti Team",
    "copyright": "© 2026 Avadeti",
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "files": [
      "main.js",
      "preload.js",
      "assets/**/*",
      "!node_modules"
    ],
    "extraResources": [
      {
        "from": "../client/build",
        "to": "../client/build",
        "filter": ["**/*"]
      }
    ],
    "protocols": [
      {
        "name": "Avadeti Deep Link",
        "schemes": ["avadeti"]
      }
    ],
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["arm64", "x64"] },
        { "target": "zip", "arch": ["arm64", "x64"] }
      ],
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "assets/entitlements.mac.plist",
      "entitlementsInherit": "assets/entitlements.mac.plist"
    },
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "icon": "assets/icon.ico"
    },
    "linux": {
      "target": [
        { "target": "AppImage", "arch": ["x64"] },
        { "target": "deb", "arch": ["x64"] }
      ],
      "category": "Office",
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false
    },
    "dmg": {
      "title": "Install Avadeti Team",
      "contents": [
        { "x": 130, "y": 220 },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ]
    }
  }
}
