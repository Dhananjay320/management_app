# Office OS — backend environment configuration
# Copy this file to `.env` and fill in real values before starting the server.

# ─── Server ──────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Database ────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://127.0.0.1:27017/office_os

# ─── JWT (auth) ──────────────────────────────────────────────────────────
# Generate strong random strings: `openssl rand -base64 48`
JWT_ACCESS_SECRET=replace-with-a-64-char-random-string
JWT_REFRESH_SECRET=replace-with-another-64-char-random-string
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# ─── AI feature key encryption ───────────────────────────────────────────
# 32+ char random string. Used to encrypt user-supplied AI provider keys.
AI_MASTER_SECRET=replace-with-32-char-secret

# ─── Web Push (VAPID) ────────────────────────────────────────────────────
# Generate a fresh keypair with: `npx web-push generate-vapid-keys`
VAPID_PUBLIC_KEY=replace-with-vapid-public-key
VAPID_PRIVATE_KEY=replace-with-vapid-private-key
VAPID_SUBJECT=mailto:admin@example.com

# ─── Mobile push (Expo / FCM) ────────────────────────────────────────────
# Only needed if you build the mobile app. Falls back to Expo's free push
# service when this isn't configured. Project ID matches mobile/app.json.
FIREBASE_PROJECT_ID=office-os
